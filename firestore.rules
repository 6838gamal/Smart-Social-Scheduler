/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model, ensuring that only authenticated users can access their own data.
 *
 * Data Structure:
 * All data is nested under `/users/{userId}`, with subcollections for connections and emails.
 *  - `/users/{userId}`: Stores user profile information.
 *  - `/users/{userId}/connections/{connectionId}`: Stores Google connection details.
 *  - `/users/{userId}/emails/{emailId}`: Stores email messages.
 *
 * Key Security Decisions:
 *  - Users can only create, read, update, and delete their own user documents and associated subcollections.
 *  - Listing of user documents or subcollections is restricted to the owner.
 *
 * Denormalization for Authorization:
 *  - The rules rely on the `userId` path segment matching the authenticated user's `uid` to enforce ownership. No additional denormalization is needed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) Authenticated user with matching UID can create their own user document.
     * @allow (get, list, update, delete) Authenticated user with matching UID can read, update, and delete their own user document.
     * @deny (create, get, list, update, delete) Any other user cannot access another user's document.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to connected account information for a user.
     * @path /users/{userId}/connections/{connectionId}
     * @allow (create) Authenticated user with matching UID can create connection document under their user document.
     * @allow (get, list, update, delete) Authenticated user with matching UID can read, update, and delete connection document under their user document.
     * @deny (create, get, list, update, delete) Any other user cannot access another user's connection documents.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/connections/{connectionId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to email messages for a user.
     * @path /users/{userId}/emails/{emailId}
     * @allow (create) Authenticated user with matching UID can create email document under their user document.
     * @allow (get, list, update, delete) Authenticated user with matching UID can read, update, and delete email document under their user document.
     * @deny (create, get, list, update, delete) Any other user cannot access another user's email documents.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/emails/{emailId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
  }
}